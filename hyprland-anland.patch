+// Anland: 传递 EGL 上下文到 Anland 后端
+static void passEGLToAnlandBackend(SP<Aquamarine::CBackend> backend) {
+#ifdef HAS_ANLAND_BACKEND
+    if (!backend || !g_pHyprOpenGL)
+        return;
+
+    EGLDisplay dpy = g_pHyprOpenGL->m_eglDisplay;
+    EGLContext ctx = g_pHyprOpenGL->m_eglContext;
+
+    if (dpy == EGL_NO_DISPLAY || ctx == EGL_NO_CONTEXT) {
+        Log::logger->log(Log::WARN, "Anland: EGL context not available yet, will retry later");
+        return;
+    }
+
+    // 确保 EGL 上下文在当前线程绑定
+    if (eglGetCurrentContext() != ctx) {
+        if (eglMakeCurrent(dpy, EGL_NO_SURFACE, EGL_NO_SURFACE, ctx) == EGL_FALSE) {
+            Log::logger->log(Log::ERR, "Anland: Failed to make EGL context current");
+            return;
+        }
+        Log::logger->log(Log::DEBUG, "Anland: EGL context made current");
+    }
+
+    for (auto const& impl : backend->getImplementations()) {
+        if (impl->type() == Aquamarine::AQ_BACKEND_ANLAND) {
+            auto* anlandImpl = static_cast<Aquamarine::CAnlandBackend*>(impl.get());
+            if (!anlandImpl)
+                continue;
+
+            auto output = anlandImpl->getOutput();
+            if (!output)
+                continue;
+
+            output->setEGL(dpy, ctx);
+
+            // 传递显式同步支持状态
+            if (g_pHyprOpenGL->explicitSyncSupported()) {
+                Log::logger->log(Log::DEBUG, "Anland: Explicit sync supported (EGL_ANDROID_native_fence_sync)");
+            } else {
+                Log::logger->log(Log::WARN, "Anland: Explicit sync NOT supported, falling back to glFinish");
+            }
+
+            Log::logger->log(Log::DEBUG, "Anland: EGL context passed to Anland backend");
+            break;
+        }
+    }
+#else
+    (void)backend;
+#endif
+}
 
